# --- Legacy API (default) ---
NUHEAT_API_TYPE=legacy
NUHEAT_EMAIL=your-email@example.com
NUHEAT_PASSWORD=your-password
NUHEAT_SERIAL_NUMBERS=SERIAL1,SERIAL2,SERIAL3

# --- OAuth2 API (uncomment to use) ---
# NUHEAT_API_TYPE=oauth2
# NUHEAT_CLIENT_ID=your-client-id
# NUHEAT_CLIENT_SECRET=your-client-secret
# NUHEAT_REDIRECT_URI=http://localhost:8787/callback

# --- Polling ---
# NUHEAT_POLL_INTERVAL=300

# --- Rate Limits ---
# NUHEAT_RATE_LIMIT_READS=60
# NUHEAT_RATE_LIMIT_WRITES=10
# NUHEAT_WRITE_THROTTLE=60

# --- Logging ---
# NUHEAT_DEBUG_LOG=false
